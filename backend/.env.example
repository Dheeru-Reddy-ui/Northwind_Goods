# ============================================================================
# Northwind Support AI — backend environment
# Copy to .env and fill in. EVERY value here is optional: with none set, the
# app runs fully offline on SQLite with the deterministic reasoning engine.
# ============================================================================

# --- Database ---------------------------------------------------------------
# Leave unset to use a local SQLite file (./northwind.db).
#
# For Supabase: Dashboard -> Project Settings -> Database -> Connection string
# -> "Connection pooling" (Transaction mode). Paste it verbatim; the app adds
# the SQLAlchemy driver + SSL automatically. Use the POOLER host
# (…pooler.supabase.com) — direct db.<ref>.supabase.co is IPv6-only and won't
# work from many hosts (e.g. Render).
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DATABASE_URL=

# --- LLM provider (Anthropic Claude) ----------------------------------------
# If set, the agent reasons with Claude. If absent, a deterministic engine
# runs the same tool-calling loop so the demo works with zero keys.
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_JUDGE_MODEL=claude-sonnet-5

# --- Retrieval (optional second-stage rerank) -------------------------------
# COHERE_API_KEY=

# --- Voice channel (optional) -----------------------------------------------
# With no keys, the browser's Web Speech API handles STT + TTS (Chrome), so the
# voice channel works offline. Set these to use server-side providers instead.
# DEEPGRAM_API_KEY=
# OPENAI_API_KEY=       # Whisper STT fallback
# ELEVENLABS_API_KEY=

# --- Tracing (optional; Postgres/SQLite trace store is the fallback) --------
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=northwind-support-ai

# --- Business rules ---------------------------------------------------------
REFUND_APPROVAL_THRESHOLD_CENTS=15000   # refunds above this need human approval
SESSION_COST_CAP_USD=0.50               # per-session cost cap; exceed -> escalate

# --- App --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
